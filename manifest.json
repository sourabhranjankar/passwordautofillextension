{
  "manifest_version": 3,
  "name": "Signup Autofill Helper",
  "description": "Store signup credentials securely and autofill email/password fields with Ctrl+Shift+F.",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Signup Autofill Helper",
    "default_popup": "popup.html"
  },
  "commands": {
    "fill-signup-form": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Fill signup form with saved email and password"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
